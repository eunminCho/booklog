{
  "expo": {
    "name": "BookLog",
    "slug": "booklog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "booklog",
    "newArchEnabled": true, 
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.booklog.app",
      "infoPlist": {
        "NSCameraUsageDescription": "책 바코드를 스캔해 서재에 추가하려면 카메라 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.booklog.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/icon.png"
        }
      ]
    ]
  }
}
