{
  "name": "@booklog/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --config ../../eslint.config.mjs .",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('No tests in apps/web yet')\"",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev --name init",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset --force"
  },
  "dependencies": {
    "@booklog/bridge": "workspace:*",
    "@booklog/design-tokens": "workspace:*",
    "@booklog/icons": "workspace:*",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "argon2": "^0.44.0",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9",
    "prisma": "^6.17.1",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
