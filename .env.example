# 용도: Neon Postgres 연결 문자열 / 예시: postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# 용도: 세션 JWT 서명 시크릿 / 예시: openssl rand -base64 32
SESSION_JWT_SECRET=

# 용도: Google Books API 호출 키(선택) / 예시: AIzaSy...
GOOGLE_BOOKS_API_KEY=

# 용도: 웹 앱의 외부 접근 URL / 예시: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
