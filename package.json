{
  "name": "booklog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter @booklog/mobile start",
    "build:bridge:force": "pnpm --filter @booklog/bridge exec tsc --build --force",
    "build:design-tokens:force": "pnpm --filter @booklog/design-tokens exec tsc --build --force",
    "build:icons:force": "pnpm --filter @booklog/icons exec tsc --build --force",
    "build:web:vercel": "pnpm run build:bridge:force && pnpm run build:design-tokens:force && pnpm run build:icons:force && pnpm --filter @booklog/web exec prisma generate && pnpm --filter @booklog/web build",
    "db:migrate": "node -e \"console.log('TODO: wire migration tool in next phase')\"",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.2"
  }
}
